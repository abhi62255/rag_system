# RAG System Configuration

# Google Gemini API Key (Get one from https://aistudio.google.com)
GOOGLE_API_KEY="AIzaSyDdcBN29DSfmh01loCJZqXk3EecaOJEETs"

# Directory for persisting Chroma vector DB
CHROMA_PERSIST_DIR=./data/chroma

# Chroma collection name
CHROMA_COLLECTION=rag_docs

# Directory to watch for document ingestion
WATCH_DIR=./data/watch

# SQLite tracking database URL
TRACKING_DB_URL=sqlite:///./data/tracking.db

# Daily ingestion sync schedule (UTC)
INGESTION_SCHEDULE_HOUR=2
INGESTION_SCHEDULE_MINUTE=0

# Retrieval settings
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.4

# Semantic chunker breakpoint settings
SEMANTIC_BREAKPOINT_TYPE=percentile
SEMANTIC_BREAKPOINT_AMOUNT=95.0
